{
  "appId": "com.syncxpro.driver",
  "appName": "SyncX Pro Driver",
  "webDir": "dist-driver",
  "android": {
    "allowMixedContent": false
  },
  "server": {
    "androidScheme": "https",
    "cleartext": false,
    "iosScheme": "capacitor"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor": "#0f172a",
      "androidSpinnerStyle": "small",
      "spinnerColor": "#60a5fa",
      "showSpinner": true
    },
    "Camera": {
      "androidxExifInterfaceVersion": "1.3.6"
    }
  },
  "ios": {
    "scheme": "SyncX Pro Driver",
    "contentInset": "always"
  }
}
